# =============================================================================
# Dual database setup (no database names are hardcoded in application code).
# =============================================================================
#
# LOGS — real-time pipeline: scanned_codes, job_operation_duration, SQL helpers
#   that read scans (e.g. update_operation_duration).
#
# APP — Prisma schema `scheduler` (machines, operations), plus jobs,
#   production_planner_paths, imposition_file_mapping, imposition_operations,
#   job_operations, processing_markers, "print OS", etc.
#
# Scan / Ticket contract (logs vs app):
#   - LOGS `scanned_codes.operations` JSONB: { "operations": ["op001", ...] } (lowercase op###).
#     `machine_id` on the row is the press id from `scheduler.Machine` when the scan was recorded.
#   - APP `scheduler.Operation` (Prisma) validates those ids (processScannedCodes).
#   - APP `machine_modes` (optional): preset bundles of operation_ids per machine for Ticket “modes”.
#
# Option A — URLs (recommended):
# DATABASE_URL is required for Prisma + app SQL.
#
# LOGS_DATABASE_URL is optional. If you omit it (and omit LOGS_DB_* below), the logs pool
# uses DATABASE_URL — same database for both (typical until you CREATE a separate DB for scans).
# Set LOGS_DATABASE_URL only when you have a dedicated database (e.g. named `logs`) that exists
# and is reachable; otherwise connection errors are common.
#
# LOGS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/logs_database_name
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/app_database_name
#
# Debug: run all planner/scan SQL (production_planner_paths, imposition_file_mapping,
# imposition_configurations) only on LOGS_DATABASE_URL — set true while debugging connection/query.
# PLANNER_USE_LOGS_ONLY=true
#
# PDF archive: imposition PDFs named `<imposition_id>.pdf` (Ticket GET /api/pdf/:impositionId).
# Use a POSIX path after mounting the share (smb:// does not work with Node fs).
# Example: smb://…/Daily Print Jobs/_NEXT HotFolder/RDevArchive/2026/foo.pdf
#   → PDF_ARCHIVE_PATH="/Volumes/Daily Print Jobs/_NEXT HotFolder/RDevArchive"
#   → resolves …/RDevArchive/2026/<imposition_id>.pdf when year subfolders are enabled (default).
# PDF_ARCHIVE_PATH="/Volumes/Daily Print Jobs/_NEXT HotFolder/RDevArchive"
# Optional: only these year folders under the archive (default: current year and two prior).
# PDF_ARCHIVE_YEAR_FOLDERS=2026,2025,2024
# PDF_ARCHIVE_TRY_YEAR_SUBFOLDERS=false
#
# Option B — parts (used when the matching URL above is unset):
# LOGS_DB_HOST=
# LOGS_DB_PORT=5432
# LOGS_DB_NAME=
# LOGS_DB_USER=
# LOGS_DB_PASSWORD=
#
# APP_DB_HOST=
# APP_DB_PORT=5432
# APP_DB_NAME=
# APP_DB_USER=
# APP_DB_PASSWORD=
#
# For local development you may point LOGS_DATABASE_URL and DATABASE_URL at the same
# database until you fully split data. After split, run migrations against each target;
# some SQL migrations assume objects coexist — see server/db/run-migrations.ts.
#
# If the server logs: relation "…" does not exist (PostgreSQL 42P01), the connection worked
# but tables are missing. Run: npm run run-migrations
# Point LOGS_DATABASE_URL at the DB that holds scanned_codes + job_operation_duration (often `logs`).
# Point DATABASE_URL at the DB that holds machines, jobs, planner tables + Prisma scheduler schema.
#
# =============================================================================
# Scheduler copy script (optional)
# =============================================================================
# SCHEDULER_MIGRATE_FROM_URL=postgresql://...
# SCHEDULER_MIGRATE_TO_URL=postgresql://...
# POSTGRES_ADMIN_URL=postgresql://superuser@HOST:5432/postgres
#
# Legacy jobmanager → app copy (optional; one-time when moving off the old DB)
# Upserts into scheduler.Machine and scheduler.Operation on DATABASE_URL. operation_id is lowercased;
# Operation.machineId is set from the target press whose display name matches the jobmanager machine (by name).
# Run: npm run run-migrations   then   npm run migrate-jobmanager-tables
# If JOBMANAGER_DATABASE_URL is unset, the script uses the same URL as DATABASE_URL but with
# database name `jobmanager`.
# JOBMANAGER_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/jobmanager
#
# Server
PORT=3001
# If you see EADDRINUSE on PORT, another process is using it — quit the old dev server or pick another PORT (and match API_PROXY_TARGET in vite).
CORS_ORIGIN=http://localhost:5173

# Vite dev proxy for /api → Express (override if API is elsewhere).
# API_PROXY_TARGET=http://127.0.0.1:3001

NODE_ENV=development

# Scheduler calendar UI (IANA). Falls back to browser timezone if unset.
# VITE_TZ=Australia/Sydney
