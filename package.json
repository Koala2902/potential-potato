{
  "name": "production-suite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "tsx scripts/prisma-with-env.ts migrate dev",
    "prisma:push": "tsx scripts/prisma-with-env.ts db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:clean": "tsx scripts/clean-scheduler-db.ts",
    "db:clean:seed": "tsx scripts/clean-scheduler-db.ts --seed",
    "db:dedupe-machines": "tsx scripts/dedupe-scheduler-machines.ts",
    "import:labex": "tsx scripts/import-labex-submissions.ts",
    "db:backfill-job-material": "tsx scripts/migrate-job-material-filename.ts",
    "db:backfill-job-schedules": "tsx scripts/backfill-job-machine-schedules.ts",
    "check-schema": "tsx server/db/check-schema.ts",
    "migrate-scheduler-db": "tsx scripts/migrate-scheduler-to-db.ts",
    "migrate-jobmanager-tables": "tsx scripts/migrate-jobmanager-tables-to-app.ts",
    "test-connection": "tsx server/db/test-connection.ts",
    "run-migrations": "tsx server/db/run-migrations.ts",
    "fix-all-job-timestamps": "tsx server/db/fix-all-job-timestamps.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "npm run prisma:push && playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "lucide-react": "^0.561.0",
    "pg": "^8.11.3",
    "prisma": "^5.22.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.54.2",
    "react-pdf": "^10.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}
